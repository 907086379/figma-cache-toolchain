# Normalize text line endings to LF in the working tree / index for listed types,
# reducing CRLF noise on Windows and matching Linux CI.
* text=auto

/.gitattributes text eol=lf

*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.svg text eol=lf

# Windows-only launch scripts keep CRLF where present
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets (if added under the repo)
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.ico -text
*.webp -text
*.tgz -text
